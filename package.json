{
	"name": "ryanacevedo",
	"type": "module",
	"version": "1.0.0",
	"packageManager": "bun@1.3.13",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"sandcastle": "bunx tsx .sandcastle/main.ts",
		"sandcastle:doctor": "bash .sandcastle/runner-permissions.sh doctor",
		"sandcastle:build-image": "bunx sandcastle docker build-image --image-name sandcastle:ryanacevedo",
		"lint": "biome lint src .sandcastle astro.config.mjs --no-errors-on-unmatched --files-ignore-unknown=true",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:e2e:case-studies": "playwright test tests/e2e/case-studies.e2e.ts",
		"test:built-site": "bun test src/lib/servicesPageConformance.test.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@ai-hero/sandcastle": "^0.12.0",
		"@astrojs/react": "6.0.1",
		"@astrojs/sitemap": "^3.7.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"astro": "7.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@playwright/test": "^1.61.1",
		"@types/bun": "^1.3.14",
		"dotenv": "^17.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"tsx": "^4.22.4",
		"typescript": "^7.0.2"
	}
}
