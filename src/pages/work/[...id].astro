---
import { type CollectionEntry, getCollection, render } from "astro:content";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import Icon from "../../components/Icon.astro";
import Pill from "../../components/Pill.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
	entry: CollectionEntry<"work">;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const work = await getCollection("work");
	return work.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="case-study stack gap-20">
		<div class="case-study__intro stack gap-15">
			<header class="case-study__header">
				<div class="wrapper stack gap-2">
					<a class="case-study__back-link" href="/work/"><Icon icon="arrow-left" /> Work</a>
					<Hero title={entry.data.title} align="start">
						<div class="case-study__details">
							<div class="case-study__tags">
								{entry.data.tags.map((tag) => <Pill>{tag}</Pill>)}
							</div>
							<p class="case-study__description">{entry.data.description}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<article class="case-study__article stack gap-10">
					{
						entry.data.img && (
							<img
								class="case-study__image"
								src={entry.data.img}
								alt={entry.data.img_alt || ''}
							/>
						)
					}
					<div class="case-study__body">
						<Content />
					</div>
				</article>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.case-study__header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.case-study__back-link {
		display: none;
	}

	.case-study__details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.case-study__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
	}

	.case-study__description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.case-study__article,
	.case-study__body {
		max-width: 65ch;
		margin-inline: auto;
	}

	.case-study__body > :global(* + *) {
		margin-top: 1rem;
	}

	.case-study__body :global(h1),
	.case-study__body :global(h2),
	.case-study__body :global(h3),
	.case-study__body :global(h4),
	.case-study__body :global(h5) {
		margin: 1.5rem 0;
	}

	.case-study__image,
	.case-study__body :global(img) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.case-study__body :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.1;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		color: var(--gray-0);
	}

	.case-study__back-link,
	.case-study__body :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.case-study__back-link:hover,
	.case-study__back-link:focus,
	.case-study__body :global(a:hover),
	.case-study__body :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (max-width: 49.999em) {
		.case-study__body {
			font-size: 1.0625rem;
			line-height: 1.618;
		}

		.case-study__body > :global(* + *) {
			margin-top: 1.618rem;
		}

		.case-study__body :global(h1),
		.case-study__body :global(h2),
		.case-study__body :global(h3),
		.case-study__body :global(h4),
		.case-study__body :global(h5) {
			line-height: 1.25;
			margin-block: 2.618rem 1.618rem;
		}

		.case-study__body :global(h1),
		.case-study__body :global(h2) {
			font-size: var(--text-xl);
		}

		.case-study__body :global(h3) {
			font-size: var(--text-lg);
		}

		.case-study__body :global(h4),
		.case-study__body :global(h5) {
			font-size: var(--text-md);
		}

		.case-study__body :global(li + li) {
			margin-top: 0.618rem;
		}

		.case-study__body :global(blockquote) {
			line-height: 1.5;
			padding-inline: 1rem;
		}

		.case-study__body :global(blockquote > p + p) {
			margin-top: 1rem;
		}
	}

	@media (min-width: 50em) {
		.case-study__back-link {
			display: block;
			align-self: flex-start;
		}

		.case-study__details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.case-study__tags {
			flex-wrap: nowrap;
			justify-content: flex-start;
		}

		.case-study__body :global(blockquote) {
			font-size: var(--text-2xl);
		}
	}
</style>
