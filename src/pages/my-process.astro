---
import Button from "../components/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BOOKING_URL, FORM_NAME } from "../lib/intakeFunnel";
---

<BaseLayout
	title="My Process | Ryan Acevedo"
	description="How Ryan Acevedo works as a forward deployed engineer to turn business problems into useful software."
>
	<!-- Signals JS availability before first paint so gated sections never flash. -->
	<script is:inline>
		document.documentElement.dataset.js = "true";
		setTimeout(() => {
			if (document.documentElement.dataset.processReady !== "true") {
				delete document.documentElement.dataset.js;
			}
		}, 3000);
	</script>
	<div class="stack gap-20">
		<main class="wrapper process-page">
			<header class="process-hero">
				<h1>
					From unclear to <em class="orange-accent">solution</em>
				</h1>
				<p class="lede">
					As a software engineer for over 10 years, I've seen
					companies stumble on the same problems over and over again.
					From seed-stage prototypes to enterprise SaaS at scale, I've
					worked with everyone from solo founders launching their
					first product to Fortune 500 companies.
				</p>
			</header>

			<section class="intro">
				<p class="lede">Typical onboarding questions I ask are:</p>
			</section>

			<section class="process-section">
				<div class="section-heading">
					<p class="eyebrow">Q1</p>
					<h2>What stage of your company are you in?</h2>
				</div>

				<ol class="steps">
					<li>
						<details
							name="company-stage"
							data-stage="Just starting"
						>
							<summary>
								<span>01</span>
								<div>
									<h3>I am just starting</h3>
									<p class="persona">
										Solo founder with an idea who needs a
										clear path forward.
									</p>
								</div>
							</summary>
							<div class="stage-details">
								<p>
									<strong>Problem:</strong> You have an idea and
									need a plan with options.
								</p>
								<p>
									<strong>Answer:</strong> We hop on a call, review
									the feasibility, create a roadmap.
								</p>
							</div>
						</details>
					</li>
					<li>
						<details name="company-stage" data-stage="Scaling">
							<summary>
								<span>02</span>
								<div>
									<h3>I am scaling</h3>
									<p class="persona">
										Growing startup with an MVP and early
										users, ready to scale.
									</p>
								</div>
							</summary>
							<div class="stage-details">
								<p>
									<strong>Problem:</strong> You have an existing
									MVP or prototype, but you're not sure how to deploy
									or scale it.
								</p>
								<p>
									<strong>Answer:</strong> I assess the current
									state of the product, identify gaps, and work
									IN your team to deploy it to your users.
								</p>
							</div>
						</details>
					</li>
					<li>
						<details
							name="company-stage"
							data-stage="Established business"
						>
							<summary>
								<span>03</span>
								<div>
									<h3>I am an established business</h3>
									<p class="persona">
										Established team ready to improve
										products and processes.
									</p>
								</div>
							</summary>
							<div class="stage-details">
								<p>
									<strong>Problem:</strong> Your customers are knocking
									down your door for features or reporting bugs,
									or you've wanted to automate a process for your
									clients for the past six months.
								</p>
								<p>
									<strong>Answer:</strong> I work IN your team and
									your codebase to solve your clients' problems.
									I speak with your customers, clear the backlog,
									and help the dev team clear the path to bring
									REAL value for your customers in weeks.
								</p>
							</div>
						</details>
					</li>
					<li>
						<details name="company-stage" data-stage="Enterprise">
							<summary>
								<span>04</span>
								<div>
									<h3>I am an enterprise</h3>
									<p class="persona">
										Enterprise team with a legacy product
										that needs momentum.
									</p>
								</div>
							</summary>
							<div class="stage-details">
								<p>
									<strong>Problem:</strong> You have a mega monolith,
									but the engineers are scrambling. The engineer
									who knew the codebase inside and out just retired
									after 20 years. The backlog is a mile long. Higher-ups
									are asking: "Have we moved to a microservice architecture
									and React 17 yet?"
								</p>
								<p>
									<strong>Answer:</strong> I help manage the team's
									backlog to get the product back under control.
									I identify the bottlenecks and build tools to
									help the teams get unstuck and increase velocity
									by 10x, and become the voice to management to
									get everyone on the same page.
								</p>
							</div>
						</details>
					</li>
				</ol>
			</section>

			<section class="impact-section" data-question="timeframe">
				<div class="section-heading">
					<p class="eyebrow">Q2</p>
					<h2 id="timeframe-heading">What's the timeframe?</h2>
					<h3 class="subtitle">How long do you need my help?</h3>
				</div>
				<div
					class="impact-grid"
					role="group"
					aria-labelledby="timeframe-heading"
				>
					<Button name="timeframe" value="1–2 weeks" pressed={false}
						>1–2 weeks</Button
					>
					<Button name="timeframe" value="1–3 months" pressed={false}
						>1–3 months</Button
					>
					<Button name="timeframe" value="3–6 months" pressed={false}
						>3–6 months</Button
					>
					<Button name="timeframe" value="6–12 months" pressed={false}
						>6–12 months</Button
					>
					<Button
						name="timeframe"
						value="1 year and beyond"
						pressed={false}
					>
						1 year and beyond
					</Button>
				</div>
			</section>

			<section class="impact-section" data-question="start">
				<div class="section-heading">
					<p class="eyebrow">Q3</p>
					<h2 id="start-heading">When do you want me to start?</h2>
				</div>
				<div
					class="impact-grid"
					role="group"
					aria-labelledby="start-heading"
				>
					<Button name="start" value="ASAP" pressed={false}
						>ASAP</Button
					>
					<Button name="start" value="1–2 weeks" pressed={false}
						>1–2 weeks</Button
					>
					<Button name="start" value="1–3 months" pressed={false}
						>1–3 months</Button
					>
				</div>
			</section>

			<div class="testimonial-stack" data-testimonials>
				<!-- Testimonial -->
				<section class="fit-section" data-testimonial="scaling">
					<!-- Testimonial: Clyde AI CTO (Scaling Quote) -->
					<blockquote>
						We would not be anywhere near where we needed to be
						without Ryan on our team. He <b
							>fixed our dev workflow</b
						> and deployed what would take a team of engineers one year
						<strong>in six weeks!</strong>
					</blockquote>
					<p>- CTO at Clyde AI</p>
				</section>

				<!-- Testimonial -->
				<section class="fit-section" data-testimonial="seed">
					<!-- Testimonial: Kyle Fowler Director of Employeer Engagement as SCC (Seed Quote) -->
					<blockquote>
						Ryan came, sat down, and got to work. He asked our
						client partners questions and watched how we work as an
						organization. From there, he built the resume app we use
						and integrated AI into the product to help us work more
						efficiently. He did all of this in a matter of two
						weeks!
					</blockquote>
					<p>- Kyle Fowler, Director of Employee Engagement at SCC</p>
				</section>

				<!-- Testimonial -->
				<section class="fit-section" data-testimonial="established">
					<!-- Testimonial: Blake Ingram, Director of Engineering at LLM (establish business quote)-->
					<blockquote>
						Ryan is a strong developer and is easy to work with. He
						made an impactful contribution to our team.
					</blockquote>
					<p>- Blake Ingram, Director of Engineering at LLM</p>
				</section>

				<!-- Testimonial -->
				<section class="fit-section" data-testimonial="enterprise">
					<!-- Testimonial: Tiding Health (Enterprise quote)-->
					<blockquote>
						Ryan connected all the dots for our B2B implementation
						of Tiding Health. He's so talented and shaped the
						platform that our patients use to this day.
					</blockquote>
					<p>- CEO of Tiding Health</p>
				</section>
			</div>
		</main>
		<aside class="contact-section" aria-labelledby="contact-heading">
			<div>
				<h2 id="contact-heading">Want to work together?</h2>
				<p>
					Tell me where to follow up, then choose a time that works
					for you.
				</p>
				<p class="brief" data-brief hidden>
					<strong>Your brief:</strong>
					<span data-brief-text></span>
				</p>
			</div>
			<form
				class="contact-form"
				data-booking-form
				name={FORM_NAME}
				action="/book"
				method="post"
				data-netlify="true"
				netlify-honeypot="bot-field"
			>
				<input type="hidden" name="form-name" value={FORM_NAME} />
				<!-- These fields enable Netlify detection and native-form fallback. -->
				<input type="hidden" name="stage" value="" />
				<input type="hidden" name="timeframe" value="" />
				<input type="hidden" name="start" value="" />
				<p hidden aria-hidden="true">
					<label>
						Don't fill this out if you're human:
						<input
							name="bot-field"
							tabindex="-1"
							autocomplete="off"
						/>
					</label>
				</p>
				<label for="contact-email">Email</label>
				<div class="contact-fields">
					<input
						id="contact-email"
						name="email"
						type="email"
						autocomplete="email"
						placeholder="you@example.com"
						required
					/>
					<Button
						type="submit"
						calLink="avocadotechgroup/discovery-call"
						calNamespace="discovery-call"
						calConfig='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
					>
						Let's talk
					</Button>
				</div>
				<p class="disclosure">
					I'll only use this to follow up about your project
				</p>
				<noscript>
					<a href={BOOKING_URL}> Book a discovery call directly </a>
				</noscript>
			</form>
		</aside>
	</div>
</BaseLayout>

<script>
	import {
		STAGES,
		buildBrief,
		buildFormPayload,
		getPromotedTestimonial,
		getRevealedQuestions,
		isStage,
		type IntakeFunnelState,
		type QuestionId,
	} from "../lib/intakeFunnel";

	const bookingForm = document.querySelector<HTMLFormElement>(
		"[data-booking-form]",
	);
	const emailInput = bookingForm?.elements.namedItem("email");
	const bookingTrigger = bookingForm?.querySelector<HTMLButtonElement>(
		"button[data-cal-link]",
	);
	const stageInput = bookingForm?.elements.namedItem("stage");
	const timeframeInput = bookingForm?.elements.namedItem("timeframe");
	const startInput = bookingForm?.elements.namedItem("start");
	const stageCards = document.querySelectorAll<HTMLDetailsElement>(
		".steps details[data-stage]",
	);
	const timeframeButtons = document.querySelectorAll<HTMLButtonElement>(
		'button[name="timeframe"]',
	);
	const startButtons = document.querySelectorAll<HTMLButtonElement>(
		'button[name="start"]',
	);
	const answerButtons = [...timeframeButtons, ...startButtons];
	const brief = document.querySelector<HTMLElement>("[data-brief]");
	const briefText = brief?.querySelector<HTMLElement>("[data-brief-text]");
	const testimonialStack = document.querySelector<HTMLElement>(
		"[data-testimonials]",
	);
	const testimonials = testimonialStack
		? Array.from(
				testimonialStack.querySelectorAll<HTMLElement>(
					"[data-testimonial]",
				),
			)
		: [];
	const questionSections = document.querySelectorAll<HTMLElement>(
		"[data-question]",
	);
	const prefersReducedMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	);
	const funnelState: IntakeFunnelState = { email: "" };
	let revealedQuestions: QuestionId[] = [];
	const renderBrief = () => {
		const text = buildBrief(funnelState);
		if (briefText) briefText.textContent = text;
		if (brief) brief.hidden = !text;
	};
	const renderQuestions = () => {
		const nextRevealed = getRevealedQuestions(funnelState, revealedQuestions);
		const newlyRevealed = nextRevealed.filter(
			(question) => !revealedQuestions.includes(question),
		);
		revealedQuestions = nextRevealed;

		for (const section of questionSections) {
			const question = section.dataset.question;
			if (question !== "timeframe" && question !== "start") continue;
			if (nextRevealed.includes(question)) {
				section.dataset.revealed = "true";
			}
		}
		if (newlyRevealed.length === 0) return;

		// One interaction reveals at most one follow-up question.
		const scrollTarget = document.querySelector<HTMLElement>(
			`[data-question="${newlyRevealed[0]}"]`,
		);
		// Only pull the viewport down when the fresh question is fully out of view.
		if (
			scrollTarget &&
			scrollTarget.getBoundingClientRect().top >= window.innerHeight
		) {
			scrollTarget.scrollIntoView({
				behavior: prefersReducedMotion.matches ? "auto" : "smooth",
				block: "start",
			});
		}
	};
	const swapActiveTestimonial = () => {
		const activeId = getPromotedTestimonial(funnelState.stage);
		for (const testimonial of testimonials) {
			testimonial.toggleAttribute(
				"data-active",
				testimonial.dataset.testimonial === activeId,
			);
		}
	};
	const renderTestimonials = () => {
		if (prefersReducedMotion.matches || !document.startViewTransition) {
			swapActiveTestimonial();
			return;
		}
		document
			.startViewTransition(swapActiveTestimonial)
			.updateCallbackDone.catch((error) =>
				console.warn("Testimonial swap failed", error),
			);
	};

	if (stageCards.length !== 4)
		console.warn("Expected four company stage cards");
	if (timeframeButtons.length !== 5)
		console.warn("Expected five timeframe buttons");
	if (startButtons.length !== 3)
		console.warn("Expected three start-date buttons");
	if (questionSections.length !== 2)
		console.warn("Expected two gated question sections");
	if (!bookingForm) {
		console.warn("Project intake booking form is missing");
	} else {
		if (!(emailInput instanceof HTMLInputElement)) {
			console.warn("Project intake email field is missing");
		}
		if (!bookingTrigger) console.warn("Cal.com booking trigger is missing");
		if (!(stageInput instanceof HTMLInputElement)) {
			console.warn("Company stage capture field is missing");
		}
		if (!(timeframeInput instanceof HTMLInputElement)) {
			console.warn("Timeframe capture field is missing");
		}
		if (!(startInput instanceof HTMLInputElement)) {
			console.warn("Start-date capture field is missing");
		}
	}
	if (!brief) console.warn("Company stage brief container is missing");
	if (!briefText) console.warn("Company stage brief text target is missing");
	if (!testimonialStack) console.warn("Testimonial stack is missing");
	if (testimonials.length !== 4) console.warn("Expected four testimonials");
	for (const stageCard of stageCards) {
		if (!isStage(stageCard.dataset.stage)) {
			console.warn("Unknown company stage", stageCard.dataset.stage);
		}
	}
	const testimonialIds = testimonials.map(
		(testimonial) => testimonial.dataset.testimonial,
	);
	for (const stage of STAGES) {
		const expectedId = getPromotedTestimonial(stage);
		const matches = testimonialIds.filter((id) => id === expectedId).length;
		if (matches === 0) console.warn("Missing testimonial", expectedId);
		if (matches > 1) console.warn("Duplicate testimonial", expectedId);
	}

	for (const stageCard of stageCards) {
		stageCard.addEventListener("toggle", () => {
			const stage = stageCard.dataset.stage;
			if (!isStage(stage)) return;

			if (!stageCard.open) {
				if (funnelState.stage !== stage) return;

				funnelState.stage = undefined;
				if (stageInput instanceof HTMLInputElement)
					stageInput.value = "";
				renderBrief();
				renderQuestions();
				renderTestimonials();
				return;
			}

			// The manual close loop backstops browsers without named-details support.
			for (const otherCard of stageCards) {
				if (otherCard !== stageCard) otherCard.open = false;
			}

			funnelState.stage = stage;
			if (stageInput instanceof HTMLInputElement) {
				stageInput.value = funnelState.stage;
			}

			renderBrief();
			renderQuestions();
			renderTestimonials();
		});
	}

	for (const answerButton of answerButtons) {
		answerButton.addEventListener("click", () => {
			const answerName = answerButton.name;
			if (answerName !== "timeframe" && answerName !== "start") return;

			const nextAnswer =
				funnelState[answerName] === answerButton.value
					? undefined
					: answerButton.value;
			funnelState[answerName] = nextAnswer;

			for (const groupButton of answerButtons) {
				if (groupButton.name === answerName) {
					groupButton.setAttribute(
						"aria-pressed",
						String(groupButton.value === nextAnswer),
					);
				}
			}

			const captureInput =
				answerName === "timeframe" ? timeframeInput : startInput;
			if (captureInput instanceof HTMLInputElement) {
				captureInput.value = nextAnswer ?? "";
			}

			renderBrief();
			renderQuestions();
		});
	}

	if (bookingForm && emailInput instanceof HTMLInputElement) {
		let captureQueued = false;
		const captureLead = () => {
			if (captureQueued) return;
			captureQueued = true;
			setTimeout(() => {
				captureQueued = false;
			}, 0);
			funnelState.email = emailInput.value;
			try {
				const botField = bookingForm.elements.namedItem("bot-field");

				void fetch(bookingForm.action, {
					method: "POST",
					headers: {
						"Content-Type": "application/x-www-form-urlencoded",
					},
					body: buildFormPayload(funnelState, {
						botField:
							botField instanceof HTMLInputElement
								? botField.value
								: "",
					}),
					keepalive: true,
				}).catch((error) => console.warn("Lead capture failed", error));
			} catch (error) {
				console.warn("Lead capture failed", error);
			}
		};

		document.addEventListener(
			"click",
			(event) => {
				if (
					!bookingTrigger ||
					!(event.target instanceof Node) ||
					!bookingTrigger.contains(event.target)
				) {
					return;
				}

				if (!bookingForm.checkValidity()) {
					event.preventDefault();
					event.stopImmediatePropagation();
					bookingForm.reportValidity();
					return;
				}

				captureLead();
				const notes = buildBrief(funnelState);
				bookingTrigger.dataset.calConfig = JSON.stringify({
					layout: "month_view",
					useSlotsViewOnSmallScreen: "true",
					email: funnelState.email,
					...(notes ? { notes } : {}),
				});
			},
			{ capture: true },
		);

		bookingForm.addEventListener("submit", (event) => {
			event.preventDefault();
			captureLead();
		});
	}

	document.documentElement.dataset.processReady = "true";
</script>

<!-- Cal element-click embed code begins -->
<script is:inline type="text/javascript">
	(function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
	Cal("init", "discovery-call", {origin:"https://app.cal.com"});
	Cal.config = Cal.config || {};
	Cal.config.forwardQueryParams = true;
	Cal.ns["discovery-call"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
</script>
<!-- Cal element-click embed code ends -->

<style>
	.orange-accent {
		color: #ca7879;
	}
	.process-page {
		display: flex;
		flex-direction: column;
		gap: 6rem;
		max-width: 68rem;
		margin-inline: auto;
	}

	.process-hero {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
		max-width: 58rem;
		padding-block: 2rem;
	}

	.process-hero h1 {
		font-size: clamp(2.75rem, 8vw, var(--text-5xl));
		max-width: 16ch;
	}

	.lede,
	.intro {
		font-size: var(--text-lg);
	}

	.lede {
		max-width: 60ch;
	}

	.intro {
		border-left: 3px solid #ca7879;
		background-color: var(--gray-999_40);
	}

	.eyebrow {
		color: #ca7879;
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.process-section,
	.impact-section {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.section-heading {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 42rem;
	}

	.section-heading h2,
	.fit-section h2 {
		font-size: var(--text-3xl);
	}

	.steps {
		display: grid;
		gap: 1rem;
		padding: 0;
	}

	.steps li {
		overflow: hidden;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
		text-align: left;
	}

	.steps summary {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 1rem;
		align-items: start;
		padding: 1rem;
		cursor: pointer;
		list-style: none;
	}

	.steps summary::-webkit-details-marker {
		display: none;
	}

	.steps summary::after {
		content: "+";
		color: var(--accent-regular);
		font-size: var(--text-xl);
		line-height: 1;
	}

	.steps details[open] summary::after {
		content: "−";
	}

	.steps summary:focus-visible {
		outline: 3px solid var(--accent-overlay);
		outline-offset: -3px;
	}

	.stage-details {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 0 1rem 1rem 3rem;
	}

	.steps span {
		color: #ca7879;
		font-family: var(--font-brand);
		font-weight: 600;
	}

	.steps h3,
	.impact-grid h3 {
		margin-bottom: 0.5rem;
		font-size: var(--text-lg);
	}

	.steps .persona {
		color: var(--gray-400);
	}

	.steps p,
	.impact-grid p,
	.fit-section > p:last-child {
		line-height: 1.7;
	}

	.impact-grid {
		display: grid;
		gap: 1rem;
	}

	.impact-grid article {
		padding: 1.5rem;
