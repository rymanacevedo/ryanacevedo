---
import CallToAction from "../components/CallToAction.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BOOKING_URL, SERVICE_OFFERS } from "../lib/servicesFitFinder";

const faqItems = [
	{
		question: "Who owns the work?",
		answer:
			"You do. Everything is built in your repo, on your infrastructure, under your accounts. Nothing is held back or licensed.",
	},
	{
		question: "Will you sign an NDA?",
		answer:
			"Case by case. Send yours over before the scoping call and I'll review it — mutual NDAs are usually an easy yes.",
	},
	{
		question: "How do we work together day-to-day?",
		answer:
			"Inside your tools — your repo, your standups, your Slack. Progress shows up as shipped pull requests, not status reports.",
	},
	{
		question: "How do you handle access and security?",
		answer:
			"Least privilege: you provision the accounts, you can revoke them any time, and access ends when the engagement does.",
	},
	{
		question: "How does payment work?",
		answer:
			"Fixed-scope engagements are a fixed price; embedded engagements bill by the block. Every price is in the written proposal — no surprises after the call.",
	},
	{
		question: "What if we're not a fit?",
		answer:
			"I'll tell you on the call — and point you at a better option if I know one.",
	},
] as const;
---

<BaseLayout
	title="Services | Ryan Acevedo"
	description="Three ways to ship practical AI product work with Ryan Acevedo."
>
	<div class="stack gap-20">
		<main class="wrapper services-page stack gap-20">
			<header class="services-hero stack gap-4">
				<p class="eyebrow">Services</p>
				<h1>What do you need <em>shipped</em>?</h1>
				<p class="lede">
					Pick the shape of your problem — I'll show you how I'd attack it.
					Your pick rides along to the booking so the call starts scoped.
				</p>
			</header>

			<section class="fit-finder stack gap-8" aria-labelledby="fit-finder-title">
				<header class="section-heading stack gap-2">
					<p class="eyebrow">Find your fit</p>
					<h2 id="fit-finder-title">What do you need shipped?</h2>
				</header>
				<div
					class="service-choices"
					role="group"
					aria-label="What do you need shipped?"
				>
					{
						SERVICE_OFFERS.map((offer) => (
							<button
								class="service-choice"
								type="button"
								data-service-choice={offer.id}
								aria-pressed="false"
							>
								<strong>{offer.need}</strong>
								<span>{offer.needDetail}</span>
								<span class="choice-action" data-choice-action>See how →</span>
							</button>
						))
					}
				</div>
				<div class="service-panels">
					{
						SERVICE_OFFERS.map((offer) => (
							<article class="offer" data-service-panel={offer.id}>
								<header class="offer-heading stack gap-2">
									<p class="eyebrow">{offer.duration}</p>
									<h3>{offer.name}</h3>
									<p class="tagline">{offer.tagline}</p>
								</header>
								<div class="offer-body stack gap-4">
									<p>
										<strong>The problem:</strong> {offer.problem}
									</p>
									<p>
										<strong>What you get:</strong> {offer.deliverables}
									</p>
									<p>{offer.proof}</p>
									<div class="good-fit">
										<h4>Good fit if…</h4>
										<ul>
											{offer.goodFit.map((line) => <li>{line}</li>)}
										</ul>
									</div>
									<p class="pricing">{offer.pricing}</p>
									<a
										class="booking-link"
										data-service-booking
										href={BOOKING_URL}
									>
										Book a discovery call
									</a>
								</div>
							</article>
						))
					}
					<p class="unscoped-booking">
						Not sure which? That's exactly what the call is for.{" "}
						<a href={BOOKING_URL}>Book it unscoped</a>{" "}— we'll figure it out
						together.
					</p>
				</div>
			</section>

			<section class="faq stack gap-8" aria-labelledby="faq-title">
				<header class="section-heading stack gap-2">
					<p class="eyebrow">Questions founders actually ask</p>
					<h2 id="faq-title">Before you book</h2>
				</header>
				<div class="faq-list">
					{
						faqItems.map((item) => (
							<details class="faq-item">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))
					}
				</div>
			</section>

			<section class="closing-cta stack gap-4" aria-labelledby="scope-title">
				<h2 id="scope-title">Let's scope your project</h2>
				<p>
					A 30-minute call: what you need shipped, whether I'm the right fit,
					and what a first engagement looks like. If it's a fit, you'll have a
					written proposal — scope, timeline, and price — within two business
					days. If I'm not, I'll tell you on the call.
				</p>
				<CallToAction href={BOOKING_URL}>Book a discovery call</CallToAction>
				<p class="floor">Engagements start at two weeks, fixed scope.</p>
			</section>
		</main>
	</div>
</BaseLayout>

<script>
	import {
		buildServiceBookingUrl,
		getOfferChoiceState,
		selectOffer,
		type FitFinderState,
		type ServiceOfferId,
	} from "../lib/servicesFitFinder";

	const choices = document.querySelectorAll<HTMLButtonElement>(
		"[data-service-choice]",
	);
	const panels = document.querySelectorAll<HTMLElement>("[data-service-panel]");
	let state: FitFinderState = {};

	function render() {
		for (const choice of choices) {
			const offerId = choice.dataset.serviceChoice as ServiceOfferId;
			const choiceState = getOfferChoiceState(state, offerId);
			choice.setAttribute("aria-pressed", String(choiceState.pressed));
			choice.dataset.selected = String(choiceState.pressed);
			choice.querySelector("[data-choice-action]")!.textContent =
				choiceState.actionText;
		}

		for (const panel of panels) {
			const offerId = panel.dataset.servicePanel as ServiceOfferId;
			const choiceState = getOfferChoiceState(state, offerId);
			panel.dataset.selected = String(choiceState.panelRevealed);
			panel.querySelector<HTMLAnchorElement>("[data-service-booking]")!.href =
				buildServiceBookingUrl(
					choiceState.panelRevealed ? offerId : undefined,
				);
		}
	}

	document.documentElement.dataset.js = "true";
	render();

	for (const choice of choices) {
		choice.addEventListener("click", () => {
			state = selectOffer(
				state,
				choice.dataset.serviceChoice as ServiceOfferId,
			);
			render();
		});
	}
</script>

<style>
	.services-page {
		max-width: 68rem;
		padding-block: 2rem;
	}

	.services-hero,
	.section-heading {
		max-width: 58rem;
	}

	.services-hero h1 {
		font-size: clamp(2.5rem, 7vw, var(--text-5xl));
	}

	.services-hero em {
		color: #ca7879;
		font-weight: 300;
	}

	.lede {
		max-width: 60ch;
		font-size: var(--text-lg);
	}

	.eyebrow {
		color: var(--accent-regular);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.section-heading h2,
	.closing-cta h2 {
		font-size: var(--text-3xl);
	}

	.service-choices,
	.service-panels {
		display: grid;
		gap: 1rem;
	}

	.service-choice {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
		width: 100%;
		padding: 1.5rem;
		color: var(--link-color);
		border: 2px solid var(--link-color);
		border-radius: 1rem;
		background: transparent;
		box-shadow: var(--shadow-sm);
		font: inherit;
		text-align: left;
		cursor: pointer;
	}

	.service-choice strong {
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		line-height: 1.1;
	}

	.choice-action {
		color: var(--accent-regular);
		font-family: var(--font-brand);
		font-weight: 700;
	}

	.service-choice:hover,
	.service-choice:focus-visible,
	.service-choice[data-selected="true"] {
		background-color: var(--accent-subtle-overlay);
	}

	.service-choice:focus-visible {
		outline: 3px solid var(--accent-regular);
		outline-offset: 3px;
	}

	.service-choice[data-selected="true"] {
		box-shadow: var(--shadow-md);
	}

	.offer {
		display: grid;
		gap: 1.5rem;
		padding: 2rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.offer h3 {
		font-size: var(--text-3xl);
	}

	.tagline,
	.pricing,
	.floor {
		color: var(--gray-400);
	}

	.tagline {
		font-size: var(--text-lg);
		font-style: italic;
	}

	.offer-body {
		line-height: 1.7;
	}

	.good-fit {
		padding: 1.25rem;
		border-left: 3px solid #ca7879;
		background-color: var(--gray-999_40);
	}

	.good-fit h4 {
		margin-bottom: 0.5rem;
		font-size: var(--text-md);
	}

	.good-fit ul {
		margin: 0;
		padding-left: 1.25rem;
		line-height: 1.7;
	}

	.booking-link {
		align-self: flex-start;
		padding: 0.56em 2em;
		color: var(--accent-text-over);
		border-radius: 999rem;
		background: var(--gradient-accent-orange);
		box-shadow: var(--shadow-md);
		font-size: var(--text-lg);
		line-height: 1.1;
		text-decoration: none;
	}

	.unscoped-booking {
		line-height: 1.7;
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.faq-item {
		padding: 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background-color: var(--gray-999_40);
	}

	.faq-item summary {
		cursor: pointer;
		font-family: var(--font-brand);
		font-weight: 600;
	}

	.faq-item p,
	.closing-cta > p {
		line-height: 1.7;
	}

	.faq-item p {
		margin-top: 0.75rem;
		color: var(--gray-300);
	}

	.closing-cta {
		padding: 3rem 2rem;
		border-block: 1px solid var(--gray-800);
		background-color: var(--gray-999_40);
	}

	.closing-cta > p {
		max-width: 60ch;
	}

	.floor {
		font-size: var(--text-sm);
	}

	@media (prefers-reduced-motion: no-preference) {
		.service-choice {
			transition:
				background-color var(--theme-transition),
				box-shadow var(--theme-transition),
				transform var(--theme-transition);
		}

		.service-choice:hover {
			transform: translateY(-0.25rem);
		}
	}

	@media (min-width: 50em) {
		.services-page {
			padding-block: 5rem;
		}

		.service-choices {
			grid-template-columns: repeat(3, 1fr);
		}

		.offer {
			grid-template-columns: minmax(14rem, 1fr) 2fr;
		}
	}
</style>

<style is:global>
	/* Keep every panel available without JavaScript; reveal only the chosen panel once it loads. */
	html[data-js] [data-service-panel]:not([data-selected="true"]) {
		display: none;
	}
</style>
