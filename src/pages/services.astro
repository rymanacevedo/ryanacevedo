---
import CallToAction from "../components/CallToAction.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BOOKING_URL } from "../lib/intakeFunnel";

const offers = [
	{
		id: "sprint",
		name: "AI Product Sprint",
		tagline: "I build it, you ship it",
		duration: "2 weeks · fixed scope",
		need: "One AI feature, live in production",
		needDetail:
			"You can name the feature in a sentence. It needs to be real, fast.",
		problem:
			"You need a production AI feature — or a validated working prototype — without spending a quarter hiring.",
		deliverables:
			"A shipped, working feature in your repo and your infrastructure. Deployed, tested, with a handoff walkthrough.",
		goodFit: [
			"You have one scoped AI feature that needs to be real",
			"You can describe it in a sentence",
			"Two weeks of focused work beats three months of hiring",
		],
		proof:
			"Proof: a production AI app scoped, built, and shipped in two weeks.",
		pricing: "Fixed price, scoped on the intake call.",
	},
	{
		id: "automation",
		name: "Workflow Automation",
		tagline: "Your team, unblocked",
		duration: "2–4 weeks",
		need: "Hours of manual work, automated",
		needDetail:
			"Triage, data entry, documents, reporting — work AI could be doing.",
		problem:
			"Your team burns hours on repetitive internal work, and nobody in-house has the time or AI depth to automate it.",
		deliverables:
			"Working automations wired into the tools you already use, and your team trained to run them.",
		goodFit: [
			"A repetitive process is eating real team hours every week",
			"The process lives in tools you already use",
			"You want your team trained on it, not dependent on me",
		],
		proof:
			"Proof: SCC's AI integration — built, adopted, and in daily use after two weeks.",
		pricing: "Scoped on the intake call.",
	},
	{
		id: "embedded",
		name: "Embedded AI Engineer",
		tagline: "I build with you",
		duration: "Ongoing · 6+ week initial block",
		need: "AI shipping every week",
		needDetail:
			"A stream of AI product work, not one feature — without months of hiring.",
		problem:
			"Your AI ambitions outpace the team's bandwidth or AI depth. You need AI product work shipping continuously.",
		deliverables:
			"I join the team — repo, standups, roadmap — and ship production AI features, with knowledge transfer built into the working style.",
		goodFit: [
			"Your AI roadmap is bigger than your team's bandwidth",
			"You want features shipping while you hire, or instead of hiring",
			"You value knowledge transfer, not a black box",
		],
		proof:
			"Proof: Clyde AI — a year of estimated work deployed in six weeks, embedded in the team.",
		pricing: "Scoped on the intake call.",
	},
] as const;

const faq = [
	{
		question: "Who owns the work?",
		answer:
			"You do. Everything is built in your repo, on your infrastructure, under your accounts. Nothing is held back or licensed.",
	},
	{
		question: "Will you sign an NDA?",
		answer:
			"Case by case. Send yours over before the scoping call and I'll review it — mutual NDAs are usually an easy yes.",
	},
	{
		question: "How do we work together day-to-day?",
		answer:
			"Inside your tools — your repo, your standups, your Slack. Progress shows up as shipped pull requests, not status reports.",
	},
	{
		question: "How do you handle access and security?",
		answer:
			"Least privilege: you provision the accounts, you can revoke them any time, and access ends when the engagement does.",
	},
	{
		question: "How does payment work?",
		answer:
			"Fixed-scope engagements are a fixed price; embedded engagements bill by the block. Every price is in the written proposal — no surprises after the call.",
	},
	{
		question: "What if we're not a fit?",
		answer:
			"I'll tell you on the call — and point you at a better option if I know one.",
	},
] as const;
---

<BaseLayout
	title="Services | Ryan Acevedo"
	description="Three ways to ship practical AI product work with Ryan Acevedo."
>
	<div class="stack gap-20">
		<main class="wrapper services-page stack gap-20">
			<header class="services-hero stack gap-4">
				<p class="eyebrow">Services</p>
				<h1>Three ways to <em>ship</em></h1>
				<p class="lede">
					Every engagement starts with the same 30-minute scoping call.
					These are the three shapes the work takes after it.
				</p>
			</header>

			<section class="offers stack gap-8" aria-labelledby="offers-title">
				<header class="section-heading stack gap-2">
					<p class="eyebrow">Find your fit</p>
					<h2 id="offers-title">What do you need shipped?</h2>
				</header>
				<ol class="offer-list">
					{
						offers.map((offer, index) => (
							<li>
								<article class="offer" data-service-offer={offer.id}>
									<header class="offer-heading stack gap-2">
										<p class="eyebrow">
											0{index + 1} · {offer.duration}
										</p>
										<h3>{offer.name}</h3>
										<p class="tagline">{offer.tagline}</p>
									</header>
									<div class="offer-body stack gap-4">
										<p class="need">
											<strong>What you need:</strong> {offer.need}
										</p>
										<p>{offer.needDetail}</p>
										<p>
											<strong>The problem:</strong> {offer.problem}
										</p>
										<p>
											<strong>What you get:</strong> {offer.deliverables}
										</p>
										<div class="good-fit">
											<h4>Good fit if…</h4>
											<ul>
												{offer.goodFit.map((line) => <li>{line}</li>)}
											</ul>
										</div>
										<p>{offer.proof}</p>
										<p class="pricing">{offer.pricing}</p>
										<CallToAction href={BOOKING_URL}>
											Book a discovery call
										</CallToAction>
									</div>
								</article>
							</li>
						))
					}
				</ol>
			</section>

			<section class="faq stack gap-8" aria-labelledby="faq-title">
				<header class="section-heading stack gap-2">
					<p class="eyebrow">Questions founders actually ask</p>
					<h2 id="faq-title">Before you book</h2>
				</header>
				<div class="faq-list">
					{
						faq.map((item) => (
							<details class="faq-item">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))
					}
				</div>
			</section>

			<section class="closing-cta stack gap-4" aria-labelledby="scope-title">
				<h2 id="scope-title">Let's scope your project</h2>
				<p>
					A 30-minute call: what you need shipped, whether I'm the right
					fit, and what a first engagement looks like. If it's a fit,
					you'll have a written proposal — scope, timeline, and price —
					within two business days. If I'm not, I'll tell you on the call.
				</p>
				<CallToAction href={BOOKING_URL}>Book a discovery call</CallToAction>
				<p class="floor">Engagements start at two weeks, fixed scope.</p>
			</section>
		</main>
	</div>
</BaseLayout>

<style>
	.services-page {
		max-width: 68rem;
		padding-block: 2rem;
	}

	.services-hero,
	.section-heading {
		max-width: 58rem;
	}

	.services-hero h1 {
		font-size: clamp(2.5rem, 7vw, var(--text-5xl));
	}

	.services-hero em {
		color: #ca7879;
		font-weight: 300;
	}

	.lede {
		max-width: 60ch;
		font-size: var(--text-lg);
	}

	.eyebrow {
		color: var(--accent-regular);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.section-heading h2,
	.closing-cta h2 {
		font-size: var(--text-3xl);
	}

	.offer-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 0;
		list-style: none;
	}

	.offer {
		display: grid;
		gap: 1.5rem;
		padding: 2rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.offer h3 {
		font-size: var(--text-3xl);
	}

	.tagline,
	.pricing,
	.floor {
		color: var(--gray-400);
	}

	.tagline {
		font-size: var(--text-lg);
		font-style: italic;
	}

	.offer-body {
		line-height: 1.7;
	}

	.need {
		font-size: var(--text-lg);
	}

	.good-fit {
		padding: 1.25rem;
		border-left: 3px solid #ca7879;
		background-color: var(--gray-999_40);
	}

	.good-fit h4 {
		margin-bottom: 0.5rem;
		font-size: var(--text-md);
	}

	.good-fit ul {
		margin: 0;
		padding-left: 1.25rem;
		line-height: 1.7;
	}

	.offer :global(.primary),
	.closing-cta :global(.primary) {
		align-self: flex-start;
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.faq-item {
		padding: 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background-color: var(--gray-999_40);
	}

	.faq-item summary {
		cursor: pointer;
		font-family: var(--font-brand);
		font-weight: 600;
	}

	.faq-item p,
	.closing-cta > p {
		line-height: 1.7;
	}

	.faq-item p {
		margin-top: 0.75rem;
		color: var(--gray-300);
	}

	.closing-cta {
		padding: 3rem 2rem;
		border-block: 1px solid var(--gray-800);
		background-color: var(--gray-999_40);
	}

	.closing-cta > p {
		max-width: 60ch;
	}

	.floor {
		font-size: var(--text-sm);
	}

	@media (min-width: 50em) {
		.services-page {
			padding-block: 5rem;
		}

		.offer {
			grid-template-columns: minmax(14rem, 1fr) 2fr;
		}
	}
</style>
