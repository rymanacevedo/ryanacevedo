---
import CallToAction from "../components/CallToAction.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const principles = [
	{
		number: "01",
		title: "Start with a real problem",
		description: "Look for friction people already feel.",
	},
	{
		number: "02",
		title: "Ship the smallest proof",
		description: "Turn theories into something customers can use.",
	},
	{
		number: "03",
		title: "Iterate",
		description:
			"Listen to what customers say and build what they actually need.",
	},
];
---

<BaseLayout
	title="Entrepreneurship | Ryan Acevedo"
	description="Founder-led businesses built through practical experimentation, software leverage, and mission-driven operating models."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-20">
			<header class="founder-hero">
				<div class="hero-copy">
					<p class="kicker">Entrepreneurship</p>
					<Hero align="start">
						<Fragment slot="title">
							Build the thing. <em>Learn from the market.</em>
						</Fragment>
						<Fragment slot="tagline">
							For fun, I like to build businesses. It's honestly
							the best way to learn how to build systems that
							actually work in the real world.
						</Fragment>
						<div class="hero-cta">
							<CallToAction
								variant="secondary"
								href="#featured-venture"
								>See the work</CallToAction
							>
						</div>
					</Hero>
				</div>
				<div class="hero-mark" aria-hidden="true">
					<span>IDEA</span>
					<Icon icon="rocket-launch" size="5rem" gradient />
					<span>IMPACT</span>
				</div>
			</header>

			<section class="method stack gap-8" aria-labelledby="method-title">
				<header class="section-heading stack gap-2">
					<p class="kicker">How I build</p>
					<h2 id="method-title">A founder's operating loop</h2>
				</header>
				<ol class="principle-grid">
					{
						principles.map((principle) => (
							<li class="principle">
								<span class="principle-number">
									{principle.number}
								</span>
								<h3>{principle.title}</h3>
								<p>{principle.description}</p>
							</li>
						))
					}
				</ol>
			</section>

			<section
				id="featured-venture"
				class="venture"
				aria-labelledby="venture-title"
			>
				<div class="venture-label">
					<p>Featured venture</p>
					<span>01</span>
				</div>
				<div class="venture-story stack gap-4">
					<p class="kicker">Service business · Social mission</p>
					<h2 id="venture-title">Mobile Oil Hero</h2>
					<p class="venture-lede">
						A mobile mechanic designed around convenience and a
						larger mission: creating real employment opportunities
						for people rebuilding their lives after incarceration.
					</p>
					<p>
						The mission is part of the operating model. Every
						service connects a practical customer need with the
						chance to fund meaningful work and a fresh start.
					</p>
					<div class="venture-links">
						<CallToAction
							variant="secondary"
							href="https://mobileoilhero.com"
							target="_blank"
							rel="noopener noreferrer"
							>Visit Mobile Oil Hero</CallToAction
						>
						<CallToAction
							variant="secondary"
							href="https://mobileoilhero.com/about-us"
							target="_blank"
							rel="noopener noreferrer"
							>Read the founder story</CallToAction
						>
					</div>
				</div>

				<div class="belief stack gap-4" aria-labelledby="belief-title">
					<Icon icon="strategy" size="2.75rem" gradient />
					<h2 id="belief-title">
						Software is leverage. The business was the outcome.
					</h2>
					<p>
						The automotive industry is ripe for change. It is
						fragmented, filled with independent mechanics who lack
						the technology to compete with dealerships, and
						underserved when it comes to convenience and
						transparency. Mobile Oil Hero was built to address these
						issues head-on, offering a modern, tech-enabled solution
						that benefits both customers and mechanics.
					</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.founder-hero {
		position: relative;
		display: grid;
		gap: 2rem;
		padding-block: 2rem;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		max-width: 54rem;
	}

	.founder-hero em {
		color: #ca7879;
		font-weight: 300;
	}

	.kicker {
		color: var(--accent-regular);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.hero-cta {
		align-self: flex-start;
		margin-top: 0.5rem;
	}

	.hero-mark {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background:
			linear-gradient(
				135deg,
				var(--accent-subtle-overlay),
				transparent 65%
			),
			var(--gray-999_40);
		box-shadow: var(--shadow-sm);
		color: var(--gray-400);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.section-heading h2,
	.venture h2,
	.belief h2 {
		font-size: var(--text-3xl);
	}

	.principle-grid {
		display: grid;
		gap: 1rem;
		padding: 0;
		list-style: none;
		counter-reset: principle;
	}

	.principle {
		position: relative;
		padding: 1.5rem;
		border-top: 3px solid #ca7879;
		border-radius: 0 0 0.75rem 0.75rem;
		background: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.principle-number {
		display: block;
		margin-bottom: 2.5rem;
		color: var(--gray-500);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
	}

	.principle h3 {
		margin-bottom: 0.75rem;
		font-size: var(--text-xl);
	}

	.principle p,
	.venture-story > p,
	.belief p {
		color: var(--gray-400);
	}

	.venture {
		display: grid;
		gap: 2rem;
		scroll-margin-top: 2rem;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background:
			linear-gradient(145deg, var(--gray-999_40), transparent),
			var(--gradient-subtle);
		box-shadow: var(--shadow-md);
	}

	.venture-label {
		display: flex;
		justify-content: space-between;
		color: var(--gray-400);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.venture-lede {
		font-size: var(--text-lg);
		line-height: 1.6;
	}

	.venture-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.5rem;
		margin-top: 0.75rem;
	}

	.venture-links a {
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	.venture-callout {
		display: flex;
		align-items: flex-end;
		padding: 1.5rem;
		border-radius: 1rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
	}

	.venture-callout p {
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		font-weight: 600;
		line-height: 1.25;
	}

	.belief {
		grid-column: 1 / -1;
		max-width: 52rem;
		padding-left: 1.5rem;
		border-left: 3px solid var(--accent-regular);
	}

	@media (min-width: 50em) {
		.founder-hero {
			grid-template-columns: minmax(0, 3fr) minmax(15rem, 1fr);
			align-items: end;
			padding-block: 5rem;
		}

		.hero-mark {
			min-height: 24rem;
			flex-direction: column;
		}

		.principle-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1.5rem;
		}

		.principle {
			padding: 2rem;
			border-radius: 0 0 1.5rem 1.5rem;
		}

		.venture {
			grid-template-columns: minmax(8rem, 0.35fr) minmax(0, 1.25fr);
			padding: 2.5rem;
		}

		.venture-label {
			flex-direction: column;
			justify-content: space-between;
		}

		.venture-callout {
			min-height: 22rem;
		}
	}
</style>
