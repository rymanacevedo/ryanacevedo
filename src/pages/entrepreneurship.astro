---
import CallToAction from "../components/CallToAction.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const principles = [
	{
		number: "01",
		title: "Start with a real problem",
		description:
			"Look for friction people already feel, then build around the outcome they actually need.",
	},
	{
		number: "02",
		title: "Ship the smallest proof",
		description:
			"Turn assumptions into something customers can use, react to, and teach you from.",
	},
	{
		number: "03",
		title: "Build the mission in",
		description:
			"Make impact part of how the business operates—not a promise bolted on after it succeeds.",
	},
];
---

<BaseLayout
	title="Entrepreneurship | Ryan Acevedo"
	description="Founder-led businesses built through practical experimentation, software leverage, and mission-driven operating models."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-20">
			<header class="founder-hero">
				<div class="hero-copy">
					<p class="kicker">Entrepreneurship</p>
					<Hero align="start">
						<Fragment slot="title">
							Build the thing.<br /><em>Learn from the market.</em>
						</Fragment>
						<Fragment slot="tagline">
							I bring an engineer's mindset to entrepreneurship: break
							the problem down, test the riskiest assumption, and keep
							building until the idea creates real value.
						</Fragment>
						<div class="hero-cta">
							<CallToAction href="#featured-venture">See the work</CallToAction>
						</div>
					</Hero>
				</div>
				<div class="hero-mark" aria-hidden="true">
					<span>IDEA</span>
					<Icon icon="rocket-launch" size="5rem" gradient />
					<span>IMPACT</span>
				</div>
			</header>

			<section class="method stack gap-8" aria-labelledby="method-title">
				<header class="section-heading stack gap-2">
					<p class="kicker">How I build</p>
					<h2 id="method-title">A founder's operating loop</h2>
				</header>
				<ol class="principle-grid">
					{
						principles.map((principle) => (
							<li class="principle">
								<span class="principle-number">{principle.number}</span>
								<h3>{principle.title}</h3>
								<p>{principle.description}</p>
							</li>
						))
					}
				</ol>
			</section>

			<section
				id="featured-venture"
				class="venture"
				aria-labelledby="venture-title"
			>
				<div class="venture-label">
					<p>Featured venture</p>
					<span>01</span>
				</div>
				<div class="venture-story stack gap-4">
					<p class="kicker">Service business · Social mission</p>
					<h2 id="venture-title">Mobile Oil Hero</h2>
					<p class="venture-lede">
						A mobile oil-change business designed around convenience
						and a larger mission: creating real employment opportunities
						for people rebuilding their lives after incarceration.
					</p>
					<p>
						The mission is part of the operating model. Every service
						connects a practical customer need with the chance to fund
						meaningful work and a fresh start.
					</p>
					<div class="venture-links">
						<a href="https://mobileoilhero.com">Visit Mobile Oil Hero</a>
						<a href="/about">Read the founder story</a>
					</div>
				</div>
				<div class="venture-callout">
					<p>Convenience and compassion aren't mutually exclusive.</p>
				</div>
			</section>

			<section class="belief stack gap-4" aria-labelledby="belief-title">
				<Icon icon="strategy" size="2.75rem" gradient />
				<h2 id="belief-title">Software is leverage. The business is the product.</h2>
				<p>
					Technology can make an operation faster, smarter, and easier
					to scale. But the durable advantage comes from understanding
					customers, designing the right system, and staying close enough
					to the work to keep learning.
				</p>
			</section>
		</main>

		<ContactCTA message="Building something that matters?" />
	</div>
</BaseLayout>

<style>
	.founder-hero {
		position: relative;
		display: grid;
		gap: 2rem;
		padding-block: 2rem;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		max-width: 54rem;
	}

	.founder-hero em {
		color: #ca7879;
		font-weight: 300;
	}

	.kicker {
		color: var(--accent-regular);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.hero-cta {
		align-self: flex-start;
		margin-top: 0.5rem;
	}

	.hero-mark {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background:
			linear-gradient(135deg, var(--accent-subtle-overlay), transparent 65%),
			var(--gray-999_40);
		box-shadow: var(--shadow-sm);
		color: var(--gray-400);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.section-heading h2,
	.venture h2,
	.belief h2 {
		font-size: var(--text-3xl);
	}

	.principle-grid {
		display: grid;
		gap: 1rem;
		padding: 0;
		list-style: none;
		counter-reset: principle;
	}

	.principle {
		position: relative;
		padding: 1.5rem;
		border-top: 3px solid #ca7879;
		border-radius: 0 0 0.75rem 0.75rem;
		background: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.principle-number {
		display: block;
		margin-bottom: 2.5rem;
		color: var(--gray-500);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
	}

	.principle h3 {
		margin-bottom: 0.75rem;
		font-size: var(--text-xl);
	}

	.principle p,
	.venture-story > p,
	.belief p {
		color: var(--gray-400);
	}

	.venture {
		display: grid;
		gap: 2rem;
		scroll-margin-top: 2rem;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background:
			linear-gradient(145deg, var(--gray-999_40), transparent),
			var(--gradient-subtle);
		box-shadow: var(--shadow-md);
	}

	.venture-label {
		display: flex;
		justify-content: space-between;
		color: var(--gray-400);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.venture-lede {
		font-size: var(--text-lg);
		line-height: 1.6;
	}

	.venture-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.5rem;
		margin-top: 0.75rem;
	}

	.venture-links a {
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	.venture-callout {
		display: flex;
		align-items: flex-end;
		padding: 1.5rem;
		border-radius: 1rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
	}

	.venture-callout p {
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		font-weight: 600;
		line-height: 1.25;
	}

	.belief {
		max-width: 52rem;
		padding-left: 1.5rem;
		border-left: 3px solid var(--accent-regular);
	}

	@media (min-width: 50em) {
		.founder-hero {
			grid-template-columns: minmax(0, 3fr) minmax(15rem, 1fr);
			align-items: end;
			padding-block: 5rem;
		}

		.hero-mark {
			min-height: 24rem;
			flex-direction: column;
		}

		.principle-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1.5rem;
		}

		.principle {
			padding: 2rem;
			border-radius: 0 0 1.5rem 1.5rem;
		}

		.venture {
			grid-template-columns: minmax(8rem, 0.35fr) minmax(0, 1.25fr) minmax(16rem, 0.7fr);
			padding: 2.5rem;
		}

		.venture-label {
			flex-direction: column;
			justify-content: space-between;
		}

		.venture-callout {
			min-height: 22rem;
		}
	}
</style>
