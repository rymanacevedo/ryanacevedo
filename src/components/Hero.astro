---
interface Props {
	title?: string;
	tagline?: string;
	align?: "start" | "center";
}

const { align = "center", tagline, title } = Astro.props;
const hasTaglineSlot = Astro.slots.has("tagline");
const hasTitleSlot = Astro.slots.has("title");
---

<div class:list={["hero stack gap-4", align]}>
	<div class="stack gap-2">
		<h1 class="title">
			{hasTitleSlot ? <slot name="title" /> : title}
		</h1>
		{
			(hasTaglineSlot || tagline) && (
				<p class="tagline">
					{hasTaglineSlot ? <slot name="tagline" /> : tagline}
				</p>
			)
		}
	</div>
	<slot />
</div>

<style>
	.hero {
		font-size: var(--text-lg);
		text-align: center;
	}

	.title,
	.tagline {
		max-width: 37ch;
		margin-inline: auto;
	}

	.title {
		font-size: var(--text-3xl);
		color: var(--gray-0);
	}

	.tagline :global(.ai-engineer-accent) {
		color: #ca7879;
	}

	@media (min-width: 50em) {
		.hero {
			font-size: var(--text-xl);
		}

		.start {
			text-align: start;
		}

		.start .title,
		.start .tagline {
			margin-inline: unset;
		}

		.title {
			font-size: var(--text-5xl);
		}
	}
</style>
